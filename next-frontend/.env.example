# Public Supabase URL and Anon Key used by the Next.js frontend to securely connect to the database and manage user sessions from the browser
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cashfree Payments API credentials for processing subscription payments and checkouts securely
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# Sarvam AI API key for fast and accurate English-to-Indic language translation across the platform UI
SARVAM_API_KEY=your_sarvam_api_key_here

# Backend API URL — set to http://localhost:8000 for local dev, or your Render service URL in production
# Example: https://threadcounty-backend.onrender.com
NEXT_PUBLIC_API_URL=your_render_backend_url_here
