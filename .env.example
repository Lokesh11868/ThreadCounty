# Supabase configuration for backend database and authentication connection
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini API key for core AI fabric analysis and thread density detection
GEMINI_API_KEY=your_gemini_api_key_here

# Brevo (formerly Sendinblue) API key for sending transactional emails and newsletters
BREVO_API_KEY=your_brevo_api_key_here

# Groq API key for fast inference of open-source language models (e.g. LLaMA) used in the AI chatbot
GROQ_API_KEY=your_groq_api_key_here
